{
  "type": "object",
  "required": ["defaultStrategy", "languageSettings", "desks"],
  "additionalProperties": false,
  "properties": {
    "defaultStrategy": {
      "type": "string",
      "enum": ["merge", "skip", "replace", "rename"]
    },
    "languageSettings": {
      "type": "object",
      "required": ["front_language", "back_language", "example_language"],
      "additionalProperties": false,
      "properties": {
        "front_language": {
          "type": "string",
          "enum": ["en", "ru", "de", "fr", "es", "it", "pt", "ja", "zh", "ko", "uk", "pl"]
        },
        "back_language": {
          "type": "string",
          "enum": ["en", "ru", "de", "fr", "es", "it", "pt", "ja", "zh", "ko", "uk", "pl"]
        },
        "example_language": {
          "type": "string",
          "enum": ["en", "ru", "de", "fr", "es", "it", "pt", "ja", "zh", "ko", "uk", "pl"]
        }
      }
    },
    "desks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/importDesk" }
    }
  },
  "definitions": {
    "importCard": {
      "type": "object",
      "required": ["front", "back", "examples"],
      "additionalProperties": false,
      "properties": {
        "front": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "back": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "examples": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "importDesk": {
      "type": "object",
      "required": [
        "clientId",
        "title",
        "tags",
        "folderPath",
        "fieldNames",
        "frontField",
        "backField",
        "exampleFields",
        "cards"
      ],
      "additionalProperties": false,
      "properties": {
        "clientId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "tags": { "type": "string" },
        "folderPath": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fieldNames": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "frontField": { "type": "string", "minLength": 1 },
        "backField": { "type": "string", "minLength": 1 },
        "exampleFields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "strategy": {
          "type": "string",
          "enum": ["merge", "skip", "replace", "rename"]
        },
        "renameTitle": { "type": "string", "minLength": 1 },
        "cards": {
          "type": "array",
          "items": { "$ref": "#/definitions/importCard" }
        }
      }
    }
  }
}
