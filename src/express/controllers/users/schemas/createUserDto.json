{
  "type": "object",
  "required": ["email", "password", "nickname"],
  "additionalProperties": false,
  "properties": {
    "email": {
      "type": "string",
      "format": "email"
    },
    "password": {
      "type": "string",
      "minLength": 5
    },
    "nickname": {
      "type": "string",
      "pattern": "^[a-z0-9_]{3,50}$",
      "minLength": 3,
      "maxLength": 50
    }
  }
}
