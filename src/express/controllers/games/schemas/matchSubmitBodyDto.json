{
  "type": "object",
  "required": ["sessionId", "pairs"],
  "additionalProperties": false,
  "properties": {
    "sessionId": {
      "format": "uuid",
      "type": "string"
    },
    "pairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["leftCardSub", "rightSlotId"],
        "additionalProperties": false,
        "properties": {
          "leftCardSub": {
            "format": "uuid",
            "type": "string"
          },
          "rightSlotId": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
