{
  "type": "object",
  "required": ["deskSub"],
  "additionalProperties": false,
  "properties": {
    "deskSub": {
      "type": "string",
      "format": "uuid"
    },
    "inviteFriendSub": {
      "type": "string",
      "format": "uuid"
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cardCount": {
          "type": "integer",
          "enum": [5, 10, 15, 20]
        },
        "mode": {
          "type": "string",
          "enum": ["write"]
        },
        "cardSet": {
          "type": "string",
          "enum": ["mirror"]
        },
        "cardPick": {
          "type": "string",
          "enum": ["random", "newest"]
        },
        "countdownSec": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "wrongAnswerLockMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "showLiveProgress": {
          "type": "boolean"
        }
      }
    }
  }
}
